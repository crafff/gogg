{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "type-enum": [
      2,
      "always",
      [
        "build",
        "chore",
        "ci",
        "docs",
        "feat",
        "fix",
        "perf",
        "refactor",
        "revert",
        "style",
        "test"
      ]
    ],
    "subject-case": [2, "never", ["pascal-case", "upper-case"]],
    "subject-max-length": [2, "always", 72],
    "body-max-line-length": [1, "always", 100],
    "footer-max-line-length": [1, "always", 120],
    "scope-enum": [
      1,
      "always",
      [
        "api",
        "worker",
        "web",
        "auth",
        "rankings",
        "champion",
        "summoner",
        "user",
        "crawler",
        "sqlc",
        "riotapi",
        "domain",
        "compose",
        "docker",
        "k8s",
        "terraform",
        "observability",
        "secrets",
        "adr",
        "scaffold",
        "ci",
        "deps"
      ]
    ]
  }
}
