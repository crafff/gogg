root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.{yaml,yml,json,toml,tf,tfvars}]
indent_size = 2
